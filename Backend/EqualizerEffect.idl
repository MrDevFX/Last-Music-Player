namespace Last_Music_Player
{
    // 10-band parametric peaking equalizer attached to MediaPlayer via
    // MediaPlayer.AddAudioEffect("Last_Music_Player.EqualizerEffect", ...).
    // Band gains are read from the IPropertySet passed to AddAudioEffect /
    // SetProperties; keys are "Band0" .. "Band9" with double values in dB.
    [default_interface]
    [marshaling_behavior(agile)]
    [threading(both)]
    runtimeclass EqualizerEffect : Windows.Media.Effects.IBasicAudioEffect
    {
        EqualizerEffect();
    }
}
