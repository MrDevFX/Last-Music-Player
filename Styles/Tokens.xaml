<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Last Music Player — Design Tokens
        Theme-varying brushes/colors live in ThemeDictionaries (Light/Dark) and are
        consumed via {ThemeResource}. Theme-independent values (radii, sizes, text
        styles, control styles) live in the root dictionary below.
    -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <!-- Accent -->
            <Color x:Key="AccentColor">#FF0097B2</Color>
            <Color x:Key="AccentColorLight">#FF00B8D4</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0097B2" />
            <SolidColorBrush x:Key="AccentBrushLight" Color="#FF00B8D4" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#1F0097B2" />
            <SolidColorBrush x:Key="AccentSoft2Brush" Color="#330097B2" />

            <!-- Surfaces -->
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFFBFBFD" />
            <SolidColorBrush x:Key="NeutralFillBrush" Color="#FFF3F4F6" />
            <SolidColorBrush x:Key="PlaceholderGlyphBrush" Color="#FFC7CDD4" />

            <!-- Gradient stop colors -->
            <Color x:Key="PanelGradient1">#FFF0FCFF</Color>
            <Color x:Key="PanelGradient2">#FFF3F0FE</Color>
            <Color x:Key="ArtPlaceholderGrad1">#FFF3EDFC</Color>
            <Color x:Key="ArtPlaceholderGrad2">#FFFCF4FE</Color>

            <!-- Strokes & dividers -->
            <Color x:Key="StrokeStrongColor">#1A000000</Color>
            <SolidColorBrush x:Key="StrokeBrush" Color="#0F000000" />
            <SolidColorBrush x:Key="StrokeStrongBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="DividerBrush" Color="#0F000000" />

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A1A1A" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF5C5C5C" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF8A8A8A" />
            <SolidColorBrush x:Key="TextDisabledBrush" Color="#FFB4B4B4" />

            <!-- Player play/pause pill -->
            <SolidColorBrush x:Key="PlayerPlayBackground" Color="#FF1A202C" />
            <SolidColorBrush x:Key="PlayerPlayForeground" Color="#FFFFFFFF" />

            <!-- Misc brand -->
            <SolidColorBrush x:Key="LikedSongsBrush" Color="#FF6B8EFE" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFD83B3B" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#1FD83B3B" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <!-- Accent -->
            <Color x:Key="AccentColor">#FF0097B2</Color>
            <Color x:Key="AccentColorLight">#FF00B8D4</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0097B2" />
            <SolidColorBrush x:Key="AccentBrushLight" Color="#FF00B8D4" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#2E0097B2" />
            <SolidColorBrush x:Key="AccentSoft2Brush" Color="#470097B2" />

            <!-- Surfaces -->
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FF2B2B2B" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF272727" />
            <SolidColorBrush x:Key="NeutralFillBrush" Color="#FF3A3A3A" />
            <SolidColorBrush x:Key="PlaceholderGlyphBrush" Color="#FF5A5A5A" />

            <!-- Gradient stop colors -->
            <Color x:Key="PanelGradient1">#FF1D2329</Color>
            <Color x:Key="PanelGradient2">#FF21202B</Color>
            <Color x:Key="ArtPlaceholderGrad1">#FF2A2233</Color>
            <Color x:Key="ArtPlaceholderGrad2">#FF1F1D2A</Color>

            <!-- Strokes & dividers -->
            <Color x:Key="StrokeStrongColor">#24FFFFFF</Color>
            <SolidColorBrush x:Key="StrokeBrush" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="StrokeStrongBrush" Color="#24FFFFFF" />
            <SolidColorBrush x:Key="DividerBrush" Color="#14FFFFFF" />

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFC8C8C8" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF9A9A9A" />
            <SolidColorBrush x:Key="TextDisabledBrush" Color="#FF6E6E6E" />

            <!-- Player play/pause pill -->
            <SolidColorBrush x:Key="PlayerPlayBackground" Color="#FFEDEDED" />
            <SolidColorBrush x:Key="PlayerPlayForeground" Color="#FF1A1A1A" />

            <!-- Misc brand -->
            <SolidColorBrush x:Key="LikedSongsBrush" Color="#FF6B8EFE" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#29FF6B6B" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ===================== Theme-independent tokens ===================== -->

    <!-- Corner radius -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>
    <CornerRadius x:Key="RadiusXl">12</CornerRadius>
    <CornerRadius x:Key="Radius2xl">16</CornerRadius>

    <!-- Sizes -->
    <x:Double x:Key="NavItemHeight">42</x:Double>

    <!-- ===================== Text styles ===================== -->

    <Style x:Key="TitleH1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="TitleH2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="TitleH3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyStrong" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
    </Style>

    <Style x:Key="EyebrowText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="160" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
    </Style>

    <!-- ===================== Control styles ===================== -->

    <SolidColorBrush x:Key="SliderTrackValueFill" Color="{ThemeResource AccentColor}" />
    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{ThemeResource AccentColorLight}" />
    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{ThemeResource AccentColorLight}" />
    <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="{ThemeResource AccentColor}" />
    <SolidColorBrush x:Key="SliderTrackFill" Color="{ThemeResource StrokeStrongColor}" />
    <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="{ThemeResource StrokeStrongColor}" />
    <SolidColorBrush x:Key="SliderTrackFillPressed" Color="{ThemeResource StrokeStrongColor}" />
    <SolidColorBrush x:Key="SliderThumbBackground" Color="{ThemeResource AccentColor}" />
    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="{ThemeResource AccentColorLight}" />
    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="{ThemeResource AccentColorLight}" />

    <!-- ToggleButton (filter chip) lightweight overrides: accent when checked -->
    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="{ThemeResource AccentColor}" Opacity="0.08" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="{ThemeResource AccentColor}" Opacity="0.14" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="{ThemeResource AccentColor}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="{ThemeResource AccentColorLight}" />
    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="{ThemeResource AccentColorLight}" />
    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="White" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="White" />
    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="White" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent" />
    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent" />

    <!-- 32x32 circular transparent icon button; subtle hover -->
    <Style x:Key="IconOnlyButton" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Stat card (Library view) -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="Padding" Value="18,18" />
    </Style>

    <!-- Settings section card -->
    <Style x:Key="SettingsCard" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="Padding" Value="18,20" />
    </Style>

    <!-- Filter chip (single-select pill) -->
    <Style x:Key="ChipToggle" TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StrokeBrush}" />
    </Style>

    <!-- Card-tile GridView container: strips the stock GridViewItem chrome.
         The app's card tiles (home carousels, search results, Browse, and the
         Library album/artist/genre/playlist grids) all carry their own hover
         affordance (a -2px translate "lift" + ThemeShadow) and never use
         selection, so the stock subtle-fill pointer-over / pressed / selected
         overlay adds nothing — and with SelectionMode=None it sticks on the
         last-clicked (now-playing) tile, because PointerExited doesn't fire
         across the playback-triggered layout change, leaving a grey box that is
         also mis-sized against the tile (default MinWidth/Padding). This
         template is a bare ContentPresenter: no visual states, no min-size, no
         padding, so the container hugs the tile and paints no background.
         Keyboard focus still shows via the framework's system focus visual. -->
    <Style x:Key="CardTileContainerStyle" TargetType="GridViewItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewItem">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Padding="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit slider style: accent filled track + accent thumb -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{ThemeResource AccentBrush}" />
    </Style>

</ResourceDictionary>
