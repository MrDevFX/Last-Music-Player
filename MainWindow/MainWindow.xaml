<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Last_Music_Player.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Last_Music_Player"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Last Music Player">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          KeyboardAcceleratorPlacementMode="Hidden">
        <!-- App-wide keyboard shortcuts. AccelPlayPause guards against firing
             while a TextBox has focus so typing Space in the search box
             doesn't pause music; the Ctrl-modifier on Prev/Next keeps them
             out of the way of any regular arrow-key navigation in list
             views. System media keys (MediaPlayPause / NextTrack /
             PreviousTrack) also work globally via SMTC.

             KeyboardAcceleratorPlacementMode="Hidden" stops WinUI from
             rendering "Space" / "Ctrl+Left" / "Ctrl+Right" tooltips on
             every hovered element — by default the platform surfaces
             accelerator key combos as accessibility hints, which is
             visually intrusive when the accelerator is bound at the
             root Grid level (effectively every UI element). The
             shortcuts themselves continue to work. -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Space" Invoked="AccelPlayPause_Invoked" />
            <KeyboardAccelerator Key="Right" Modifiers="Control" Invoked="AccelNext_Invoked" />
            <KeyboardAccelerator Key="Left" Modifiers="Control" Invoked="AccelPrev_Invoked" />
        </Grid.KeyboardAccelerators>

        <!-- Row 0: App Body (Sidebars and Content), Row 1: Bottom Music Player -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="90" />
        </Grid.RowDefinitions>

        <!-- Main Body -->
        <Grid x:Name="MainBodyGrid" Grid.Row="0" SizeChanged="MainBodyGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="240" /> <!-- Left Sidebar -->
                <ColumnDefinition Width="*" />   <!-- Center Content -->
                <ColumnDefinition x:Name="RightRailColumn" Width="300" /> <!-- Right Sidebar (auto-widens on Lyrics tab) -->
            </Grid.ColumnDefinitions>

            <!-- Responsive: full-screen widens both rails for breathing room;
                 right rail collapses below 1100px wide -->
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="FullLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1500" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="LeftSidebarColumn.Width" Value="300" />
                            <Setter Target="RightRailColumn.Width" Value="380" />
                            <Setter Target="RightSidebar.Visibility" Value="Visible" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1100" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="RightRailColumn.Width" Value="300" />
                            <Setter Target="RightSidebar.Visibility" Value="Visible" />
                            <Setter Target="SettingsNavColumn.Width" Value="56" />
                            <Setter Target="SettingsNavPanel.Margin" Value="0,0,12,0" />
                            <Setter Target="SetLabelLibrary.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelPlayback.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAudio.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAppearance.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelIntegrations.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAbout.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillLibrary.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillPlayback.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAudio.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAppearance.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillIntegrations.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAbout.Visibility" Value="Collapsed" />
                            <Setter Target="MusicFolderActions.(Grid.Column)" Value="1" />
                            <Setter Target="MusicFolderActions.(Grid.Row)" Value="1" />
                            <Setter Target="MusicFolderActions.HorizontalAlignment" Value="Left" />
                            <Setter Target="MusicFolderActions.Margin" Value="0,12,0,0" />
                            <Setter Target="ScanMusicButton.(Grid.Column)" Value="1" />
                            <Setter Target="ScanMusicButton.(Grid.Row)" Value="1" />
                            <Setter Target="ScanMusicButton.HorizontalAlignment" Value="Left" />
                            <Setter Target="ScanMusicButton.Margin" Value="0,12,0,0" />
                            <Setter Target="AutoplaySwitch.(Grid.Column)" Value="0" />
                            <Setter Target="AutoplaySwitch.(Grid.Row)" Value="1" />
                            <Setter Target="AutoplaySwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="AutoplaySwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="GaplessSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="GaplessSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="GaplessSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="GaplessSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="CloseBehaviorCombo.(Grid.Column)" Value="0" />
                            <Setter Target="CloseBehaviorCombo.(Grid.Row)" Value="1" />
                            <Setter Target="CloseBehaviorCombo.HorizontalAlignment" Value="Left" />
                            <Setter Target="CloseBehaviorCombo.Margin" Value="0,12,0,0" />
                            <Setter Target="OutputDeviceCombo.(Grid.Column)" Value="0" />
                            <Setter Target="OutputDeviceCombo.(Grid.Row)" Value="1" />
                            <Setter Target="OutputDeviceCombo.HorizontalAlignment" Value="Left" />
                            <Setter Target="OutputDeviceCombo.Margin" Value="0,12,0,0" />
                            <Setter Target="ThemeOptionsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ThemeOptionsPanel.(Grid.Row)" Value="1" />
                            <Setter Target="ThemeOptionsPanel.HorizontalAlignment" Value="Left" />
                            <Setter Target="ThemeOptionsPanel.Margin" Value="0,12,0,0" />
                            <Setter Target="AccentSwatchesPanel.(Grid.Column)" Value="0" />
                            <Setter Target="AccentSwatchesPanel.(Grid.Row)" Value="1" />
                            <Setter Target="AccentSwatchesPanel.HorizontalAlignment" Value="Left" />
                            <Setter Target="AccentSwatchesPanel.Margin" Value="0,12,0,0" />
                            <Setter Target="ShowAlbumArtSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="ShowAlbumArtSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="ShowAlbumArtSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="ShowAlbumArtSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="DiscordPresenceSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="DiscordPresenceSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="DiscordPresenceSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="DiscordPresenceSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="WindowsMediaControlsSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="WindowsMediaControlsSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="WindowsMediaControlsSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="WindowsMediaControlsSwitch.Margin" Value="0,12,0,0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NarrowLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="RightRailColumn.Width" Value="0" />
                            <Setter Target="RightSidebar.Visibility" Value="Collapsed" />
                            <Setter Target="SettingsNavColumn.Width" Value="56" />
                            <Setter Target="SettingsNavPanel.Margin" Value="0,0,12,0" />
                            <Setter Target="SetLabelLibrary.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelPlayback.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAudio.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAppearance.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelIntegrations.Visibility" Value="Collapsed" />
                            <Setter Target="SetLabelAbout.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillLibrary.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillPlayback.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAudio.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAppearance.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillIntegrations.Visibility" Value="Collapsed" />
                            <Setter Target="SetPillAbout.Visibility" Value="Collapsed" />

                            <Setter Target="MusicFolderActions.(Grid.Column)" Value="1" />
                            <Setter Target="MusicFolderActions.(Grid.Row)" Value="1" />
                            <Setter Target="MusicFolderActions.HorizontalAlignment" Value="Left" />
                            <Setter Target="MusicFolderActions.Margin" Value="0,12,0,0" />
                            <Setter Target="ScanMusicButton.(Grid.Column)" Value="1" />
                            <Setter Target="ScanMusicButton.(Grid.Row)" Value="1" />
                            <Setter Target="ScanMusicButton.HorizontalAlignment" Value="Left" />
                            <Setter Target="ScanMusicButton.Margin" Value="0,12,0,0" />

                            <Setter Target="AutoplaySwitch.(Grid.Column)" Value="0" />
                            <Setter Target="AutoplaySwitch.(Grid.Row)" Value="1" />
                            <Setter Target="AutoplaySwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="AutoplaySwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="GaplessSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="GaplessSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="GaplessSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="GaplessSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="CloseBehaviorCombo.(Grid.Column)" Value="0" />
                            <Setter Target="CloseBehaviorCombo.(Grid.Row)" Value="1" />
                            <Setter Target="CloseBehaviorCombo.HorizontalAlignment" Value="Left" />
                            <Setter Target="CloseBehaviorCombo.Margin" Value="0,12,0,0" />
                            <Setter Target="OutputDeviceCombo.(Grid.Column)" Value="0" />
                            <Setter Target="OutputDeviceCombo.(Grid.Row)" Value="1" />
                            <Setter Target="OutputDeviceCombo.HorizontalAlignment" Value="Left" />
                            <Setter Target="OutputDeviceCombo.Margin" Value="0,12,0,0" />
                            <Setter Target="ThemeOptionsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ThemeOptionsPanel.(Grid.Row)" Value="1" />
                            <Setter Target="ThemeOptionsPanel.HorizontalAlignment" Value="Left" />
                            <Setter Target="ThemeOptionsPanel.Margin" Value="0,12,0,0" />
                            <Setter Target="AccentSwatchesPanel.(Grid.Column)" Value="0" />
                            <Setter Target="AccentSwatchesPanel.(Grid.Row)" Value="1" />
                            <Setter Target="AccentSwatchesPanel.HorizontalAlignment" Value="Left" />
                            <Setter Target="AccentSwatchesPanel.Margin" Value="0,12,0,0" />
                            <Setter Target="ShowAlbumArtSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="ShowAlbumArtSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="ShowAlbumArtSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="ShowAlbumArtSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="DiscordPresenceSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="DiscordPresenceSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="DiscordPresenceSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="DiscordPresenceSwitch.Margin" Value="0,12,0,0" />
                            <Setter Target="WindowsMediaControlsSwitch.(Grid.Column)" Value="0" />
                            <Setter Target="WindowsMediaControlsSwitch.(Grid.Row)" Value="1" />
                            <Setter Target="WindowsMediaControlsSwitch.HorizontalAlignment" Value="Left" />
                            <Setter Target="WindowsMediaControlsSwitch.Margin" Value="0,12,0,0" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Custom TitleBar Drag Region overlay (app mark + title on the left;
                 system caption buttons are drawn by WinUI on the right). -->
            <Grid x:Name="AppTitleBar"
                  Height="48"
                  VerticalAlignment="Top"
                  Grid.Column="0" Grid.ColumnSpan="3"
                  Canvas.ZIndex="100"
                  Background="Transparent">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0">
                    <Border Width="26" Height="26" CornerRadius="{StaticResource RadiusMd}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{ThemeResource AccentColor}" Offset="0.0" />
                                <GradientStop Color="{ThemeResource AccentColorLight}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#x266A;" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Last Music Player" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Left Sidebar Navigation -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" /> <!-- Logo/Spacer -->
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" /> <!-- Profile section -->
                </Grid.RowDefinitions>

                <!-- Row 0 is a spacer: the app mark + title now live in the custom
                     title bar (AppTitleBar) so the brand isn't duplicated here.
                     It also hosts invisible "brush probes" bound to the theme
                     resources. EnsureAccentBrushes() reads the resolved brushes
                     off these (never reassigned) elements so they stay
                     theme-correct even after nav foregrounds are overwritten. -->
                <Border Grid.Row="0">
                    <StackPanel x:Name="BrushProbes" Opacity="0" IsHitTestVisible="False" Width="0" Height="0">
                        <FontIcon x:Name="ProbeAccent" Foreground="{ThemeResource AccentBrush}" />
                        <Border x:Name="ProbeAccentSoft" Background="{ThemeResource AccentSoftBrush}" />
                        <FontIcon x:Name="ProbeGlyphIdle" Foreground="{ThemeResource TextSecondaryBrush}" />
                        <TextBlock x:Name="ProbeLabelIdle" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <Border x:Name="ProbeTransparent" Background="Transparent" />
                        <Border x:Name="ProbeStroke" BorderBrush="{ThemeResource StrokeBrush}" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="0, 20, 0, 0">
                    <StackPanel Padding="16,0,16,0" Spacing="2">
                        <TextBlock Text="MENU" Style="{StaticResource EyebrowText}" Margin="0, 0, 0, 10"/>

                        <!-- Nav Items -->
                        <Button x:Name="HomeButton" Click="HomeButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="{ThemeResource AccentSoftBrush}" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <FontIcon x:Name="HomeGlyph" Glyph="&#xE80F;" Foreground="{ThemeResource AccentBrush}" FontSize="16"/>
                                    <TextBlock x:Name="HomeLabel" Text="Home" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="BrowseButton" Click="BrowseButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <FontIcon x:Name="BrowseGlyph" Glyph="&#xE721;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="16"/>
                                    <TextBlock x:Name="BrowseLabel" Text="Browse" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="LibraryButton" Click="LibraryButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <FontIcon x:Name="LibraryGlyph" Glyph="&#xE8D6;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="16"/>
                                    <TextBlock x:Name="LibraryLabel" Text="Library" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="SettingsButton" Click="SettingsNav_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                    <FontIcon x:Name="SettingsGlyph" Glyph="&#xE713;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="16"/>
                                    <TextBlock x:Name="SettingsLabel" Text="Settings" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <TextBlock Text="PLAYLISTS" Style="{StaticResource EyebrowText}" Margin="0, 24, 0, 10"/>

                        <Button x:Name="LikedSongsButton" Click="LikedSongsButton_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Padding="12,10">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Border Background="{ThemeResource LikedSongsBrush}" CornerRadius="{StaticResource RadiusSm}" Width="24" Height="24">
                                    <FontIcon Glyph="&#xEB51;" Foreground="White" FontSize="12"/>
                                </Border>
                                <TextBlock Text="Liked Songs" VerticalAlignment="Center" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <ListView x:Name="SidebarPlaylistsListView"
                                  IsItemClickEnabled="True"
                                  ItemClick="SidebarPlaylist_ItemClick"
                                  SelectionMode="None"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="42" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:TrackInfo">
                                    <Grid Padding="12,9" ColumnSpacing="16">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryGroupMenuPlayNow_Click" />
                                                <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryGroupMenuPlayNext_Click" />
                                                <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryGroupMenuAddToQueue_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Rename playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryPlaylistRename_Click" />
                                                <MenuFlyoutItem Text="Delete playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryPlaylistDelete_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{ThemeResource NeutralFillBrush}" CornerRadius="{StaticResource RadiusSm}" Width="24" Height="24">
                                            <TextBlock Text="#" Foreground="{ThemeResource TextTertiaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Title}" VerticalAlignment="Center" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <!-- Profile Section -->
                <Border Grid.Row="2" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,1,0,0" Padding="16, 20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- Avatar: user-silhouette glyph centred inside an accent ring.
                             Name-agnostic; the sidebar text label below still shows the
                             current UserDisplayName. -->
                        <Grid Width="40" Height="40">
                            <Ellipse Stroke="{ThemeResource AccentBrush}" StrokeThickness="1.5">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="Transparent" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <FontIcon Glyph="&#xE77B;" FontSize="22" Foreground="{ThemeResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock x:Name="ProfileSidebarName" Text="Listener" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                            <TextBlock Text="PREMIUM" FontSize="10" Foreground="{ThemeResource AccentBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Center Content Panel -->
            <Grid Grid.Column="1" Padding="16,24,16,0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{ThemeResource PanelGradient1}" Offset="0.0"/>
                        <GradientStop Color="{ThemeResource PanelGradient2}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- ========== HOME VIEW ========== -->
                <Grid x:Name="HomeViewContainer">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Search Bar -->
                    <RowDefinition Height="*"/>    <!-- Scrollable content -->
                </Grid.RowDefinitions>

                <!-- Search Bar (outer wrapper emulates the CSS accent-soft focus glow) -->
                <Border x:Name="SearchGlow" Grid.Row="0" Margin="0,16,0,28" CornerRadius="22" BorderBrush="Transparent" BorderThickness="2" Padding="0">
                    <Border x:Name="SearchBorder" Margin="0" CornerRadius="20" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" Height="40" Padding="18,0,16,0" UseLayoutRounding="True">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE721;" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="16" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <!-- Using TextBox styled as transparent to act as AutoSuggestBox without border -->
                            <TextBox x:Name="GlobalSearchBox" Grid.Column="1" PlaceholderText="Search local or remote music..." AutomationProperties.Name="Search local or remote music" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}" GotFocus="GlobalSearchBox_GotFocus" LostFocus="GlobalSearchBox_LostFocus" KeyDown="GlobalSearchBox_KeyDown" TextChanged="GlobalSearchBox_TextChanged"/>
                            <Border Grid.Column="2" VerticalAlignment="Center" Height="22" CornerRadius="11" BorderThickness="1" BorderBrush="{ThemeResource StrokeBrush}" Background="{ThemeResource NeutralFillBrush}" Padding="8,0" IsHitTestVisible="False">
                                <TextBlock Text="Ctrl + K" FontSize="11" FontWeight="SemiBold" CharacterSpacing="40" VerticalAlignment="Center" Foreground="{ThemeResource TextTertiaryBrush}" />
                            </Border>
                        </Grid>
                    </Border>
                </Border>

                <!-- Negative right margin reaches past the outer Grid's right padding
                     so the vertical scrollbar lands flush against the Up Next rail.
                     The matching right padding on each ScrollViewer's inner StackPanel
                     absorbs the extra width — tiles and section titles keep their
                     visual right-edge inset. Values track the outer Grid's right
                     padding (currently 16). -->
                <Grid Grid.Row="1" Margin="0,0,-16,0">
                <ScrollViewer x:Name="HomeDefaultContent" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="32" Padding="0,0,16,32">

                        <!-- Time-aware greeting. Header-style text that scrolls away with
                             the rest of the content. The actual string ("Good morning…",
                             user name) is set in C++ via UpdateHomeGreeting on each Home
                             hydration. -->
                        <TextBlock x:Name="HomeGreeting" Text="Welcome back" Style="{StaticResource TitleH1}" Margin="0,8,0,-8" />

                        <!-- Listen Again Section -->
                        <StackPanel>
                            <Grid Margin="0,0,0,16" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <TextBlock x:Name="HomeResultsTitle" Text="Listen Again" Style="{StaticResource TitleH2}" />
                                    <Border Background="{ThemeResource NeutralFillBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="999" Padding="9,3" VerticalAlignment="Center">
                                        <TextBlock x:Name="HomeResultsBadgeText" Text="History" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" FontWeight="SemiBold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <Button x:Name="HomeListenAllButton" Content="See all &#x203A;" Click="HomeListenAll_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="6,2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                            </Grid>

                            <GridView x:Name="HomeRecentGridView"
                                      Height="260"
                                      Padding="0,4,64,24"
                                      Visibility="Collapsed"
                                      IsItemClickEnabled="True"
                                      ItemClick="HomeRecentGridView_ItemClick"
                                      ItemContainerStyle="{StaticResource CardTileContainerStyle}"
                                      SelectionMode="None"
                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TrackInfo">
                                        <!-- Explicit row grid keeps the title row a fixed 40 px
                                             (2 BodyStrong lines max). Short titles leave the
                                             extra line blank; artist and source labels always
