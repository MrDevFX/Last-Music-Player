                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <StackPanel>
                                            <Border Width="184" Height="184" CornerRadius="{StaticResource Radius2xl}" Margin="0,0,0,10" Translation="0,0,16">
                                                <Border.Shadow><ThemeShadow /></Border.Shadow>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF2BD48F" Offset="0.0"/>
                                                        <GradientStop Color="#FF8BE36B" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid>
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="90" Foreground="White" Opacity="0.18" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-8,0" IsHitTestVisible="False"/>
                                                    <Border IsHitTestVisible="False" CornerRadius="{StaticResource Radius2xl}">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                                                                <GradientStop Color="#00FFFFFF" Offset="0.4"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <TextBlock Text="FRESH FINDS" FontSize="11" FontWeight="Bold" CharacterSpacing="180" Foreground="White" Opacity="0.95" VerticalAlignment="Top" Margin="14"/>
                                                    <TextBlock Text="The latest additions to your library." FontSize="12" FontWeight="Medium" Foreground="White" Opacity="0.94" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" LineHeight="17" VerticalAlignment="Bottom" Margin="14"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="Fresh Finds" Style="{StaticResource BodyStrong}"/>
                                            <TextBlock Text="Made for you" Style="{StaticResource CaptionText}"/>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>

                        <!-- Most Played Section. Populated from LoadMostPlayedTracks
                             (ordered by PlayCount). Section is initially collapsed and
                             revealed in C++ only when the user has at least a few
                             repeat-played tracks so we don't show an empty header on
                             first launch. -->
                        <StackPanel x:Name="HomeMostPlayedSection" Visibility="Collapsed">
                            <Grid Margin="0,0,0,16" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <TextBlock Text="Most Played" Style="{StaticResource TitleH2}" />
                                    <Border Background="{ThemeResource NeutralFillBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="999" Padding="9,3" VerticalAlignment="Center">
                                        <TextBlock Text="TOP HITS" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" FontWeight="SemiBold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <Button x:Name="HomeMostPlayedSeeAllButton" Content="See all &#x203A;" Click="HomeMostPlayedSeeAll_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="6,2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                            </Grid>
                            <GridView x:Name="HomeMostPlayedGridView"
                                      Height="260"
                                      Padding="0,4,64,24"
                                      IsItemClickEnabled="True"
                                      ItemClick="HomeMostPlayed_ItemClick"
                                      ItemContainerStyle="{StaticResource CardTileContainerStyle}"
                                      SelectionMode="None"
                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TrackInfo">
                                        <!-- Fixed-row grid so 2-line titles don't shift artist
                                             text down — neighbouring cards stay vertically
                                             aligned regardless of title length. -->
                                        <Grid Width="156" Margin="0,0,20,0" VerticalAlignment="Top"
                                              PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="156" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="18" />
                                            </Grid.RowDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="HomeRowMenuPlayNow_Click" />
                                                    <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                                    <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                                    <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                    <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid Grid.Row="0" Width="156" Height="156">
                                                <Border CornerRadius="{StaticResource Radius2xl}" Translation="0,0,16">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#FFA042" Offset="0" />
                                                            <GradientStop Color="#FF3B6A" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Shadow>
                                                        <ThemeShadow />
                                                    </Border.Shadow>
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="36" Foreground="White" Opacity="0.55" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                            <TextBlock Grid.Row="2" Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" />
                                            <TextBlock Grid.Row="3" Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>

                        <!-- Liked Songs Highlights Section. Reads from the existing
                             "Liked" track filter. Hidden when the user hasn't liked
                             anything yet. -->
                        <StackPanel x:Name="HomeLikedSection" Visibility="Collapsed">
                            <Grid Margin="0,0,0,16" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <TextBlock Text="Your Liked Songs" Style="{StaticResource TitleH2}" />
                                    <Border Background="{ThemeResource NeutralFillBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="999" Padding="9,3" VerticalAlignment="Center">
                                        <TextBlock Text="FAVOURITES" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" FontWeight="SemiBold" CharacterSpacing="40" />
                                    </Border>
                                </StackPanel>
                                <Button x:Name="HomeLikedSeeAllButton" Content="See all &#x203A;" Click="HomeLikedSeeAll_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="6,2" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" />
                            </Grid>
                            <GridView x:Name="HomeLikedGridView"
                                      Height="260"
                                      Padding="0,4,64,24"
                                      IsItemClickEnabled="True"
                                      ItemClick="HomeLiked_ItemClick"
                                      ItemContainerStyle="{StaticResource CardTileContainerStyle}"
                                      SelectionMode="None"
                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollMode="Enabled"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsStackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TrackInfo">
                                        <Grid Width="156" Margin="0,0,20,0" VerticalAlignment="Top"
                                              PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="156" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="18" />
                                            </Grid.RowDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="HomeRowMenuPlayNow_Click" />
                                                    <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                                    <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                                    <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                    <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid Grid.Row="0" Width="156" Height="156">
                                                <Border CornerRadius="{StaticResource Radius2xl}" Translation="0,0,16">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#FF6BD0" Offset="0" />
                                                            <GradientStop Color="#C04BFE" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Shadow>
                                                        <ThemeShadow />
                                                    </Border.Shadow>
                                                    <FontIcon Glyph="&#xEB52;" FontSize="36" Foreground="White" Opacity="0.55" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                            <TextBlock Grid.Row="2" Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" />
                                            <TextBlock Grid.Row="3" Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>

                        <!-- Recently Added Section. Hidden when no library tracks
                             have a meaningful DateAddedSortKey — search-result
                             remote tracks land with key=0 and would otherwise
                             dominate the carousel meaninglessly. Hidden state
                             matches Most Played + Liked Songs behaviour. -->
                        <StackPanel x:Name="HomeRecentlyAddedSection" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,16" VerticalAlignment="Center">
                                <TextBlock Text="Recently Added" Style="{StaticResource TitleH2}" />
                                <Border Background="{ThemeResource NeutralFillBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="999" Padding="9,3" VerticalAlignment="Center">
                                    <TextBlock Text="LOCAL" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" FontWeight="SemiBold" CharacterSpacing="40" />
                                </Border>
                            </StackPanel>

                            <GridView x:Name="HomeRecentlyAddedGridView"
                                      Visibility="Collapsed"
                                      SelectionMode="None"
                                      IsItemClickEnabled="True"
                                      ItemClick="HomeRecentlyAdded_ItemClick"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="3" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,16,0" />
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TrackInfo">
                                        <Grid Width="380" Padding="6" Margin="0,0,0,2" CornerRadius="{StaticResource RadiusMd}" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="HomeRowMenuPlayNow_Click" />
                                                    <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                                    <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                                    <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                    <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid Grid.Column="0" Width="44" Height="44">
                                                <Border CornerRadius="{StaticResource RadiusMd}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#14A8BC" Offset="0" />
                                                            <GradientStop Color="#7F6CFF" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="16" Foreground="White" Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{x:Bind Artist}" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text=" &#x00B7; " FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" />
                                                    <TextBlock Text="{x:Bind Album}" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Duration}" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" />
                                                <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource TextTertiaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <!-- Empty state: shown until there are tracks in the library -->
                            <TextBlock x:Name="RecentlyAddedEmptyText"
                                       Text="Play something to see it here"
                                       Visibility="Collapsed"
                                       Margin="0,4,0,0"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextTertiaryBrush}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="HomeSearchContent" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="28" Padding="0,0,16,32">
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <TextBlock Text="Search" Style="{StaticResource TitleH1}" />
                            <Border BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                                <TextBlock x:Name="SearchStatusText" Text="Type to search" FontSize="10" Foreground="{ThemeResource TextTertiaryBrush}" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="14">
                            <TextBlock Text="Results" Style="{StaticResource TitleH2}" />
                            <GridView x:Name="SearchSongsListView"
                                      SelectionMode="None"
                                      IsItemClickEnabled="True"
                                      ItemClick="SearchResult_ItemClick"
                                      ItemContainerStyle="{StaticResource CardTileContainerStyle}"
                                      Padding="0,4,0,24"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- ItemHeight = card 244 + 18 bottom margin; titles wrap to
                                             two lines max without pushing the source label off the
                                             bottom of the card. -->
                                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="160" ItemHeight="262" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TrackInfo">
                                        <!-- Explicit row layout keeps cards aligned in the grid even
                                             when titles vary from one to two lines: the title row is
                                             fixed at 40px (room for two BodyStrong lines), and short
                                             titles leave that row partially blank instead of letting
                                             the artist/source rows drift up. Source label uses
                                             TextTrimming so unusually long provider names ellipsize. -->
                                        <Grid x:Name="SearchCardRoot" Width="146" Height="244" Margin="0,0,14,18" VerticalAlignment="Top"
                                              PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="146" />
                                                <RowDefinition Height="12" />
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="18" />
                                                <RowDefinition Height="18" />
                                            </Grid.RowDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="HomeRowMenuPlayNow_Click" />
                                                    <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                                    <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                                    <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                    <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Grid Grid.Row="0" Width="146" Height="146">
                                                <Border CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource NeutralFillBrush}" Translation="0,0,16">
                                                    <Border.Shadow>
                                                        <ThemeShadow />
                                                    </Border.Shadow>
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="32" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                            <TextBlock Grid.Row="2" Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" />
                                            <TextBlock Grid.Row="3" Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="4" Text="{x:Bind DateAdded}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" Opacity="0.8" />
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </Grid>
                </Grid>

                <!-- ========== SETTINGS VIEW ========== -->
                <Grid x:Name="SettingsViewContainer" Visibility="Collapsed" Padding="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Header -->
                        <RowDefinition Height="*" />    <!-- Nav + content -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
                        <TextBlock Text="PREFERENCES" Style="{StaticResource EyebrowText}" />
                        <TextBlock Text="Settings" Style="{StaticResource TitleH1}" />
                        <TextBlock Text="Tune playback, library and appearance" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="SettingsNavColumn" Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Settings sub-nav -->
                        <StackPanel x:Name="SettingsNavPanel" Grid.Column="0" Spacing="2" Margin="0,0,24,0">
                            <Button x:Name="SetNavProfile" Tag="Profile" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="{ThemeResource AccentSoftBrush}" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillProfile" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Visible" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphProfile" Glyph="&#xE77B;" Foreground="{ThemeResource AccentBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelProfile" Text="Profile" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavLibrary" Tag="Library" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillLibrary" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphLibrary" Glyph="&#xE8D6;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelLibrary" Text="Library" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavPlayback" Tag="Playback" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillPlayback" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphPlayback" Glyph="&#xE768;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelPlayback" Text="Playback" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavAudio" Tag="Audio" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillAudio" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphAudio" Glyph="&#xE767;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelAudio" Text="Audio" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavAppearance" Tag="Appearance" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillAppearance" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphAppearance" Glyph="&#xE790;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelAppearance" Text="Appearance" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavIntegrations" Tag="Integrations" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillIntegrations" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphIntegrations" Glyph="&#xE71B;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelIntegrations" Text="Integrations" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button x:Name="SetNavAbout" Tag="About" Click="SettingsSection_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusLg}" Height="42" Padding="12,0">
                                <Grid>
                                    <Border x:Name="SetPillAbout" HorizontalAlignment="Left" VerticalAlignment="Center" Width="3" Height="16" CornerRadius="1.5" Background="{ThemeResource AccentBrush}" Margin="-4,0,0,0" Visibility="Collapsed" />
                                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon x:Name="SetGlyphAbout" Glyph="&#xE946;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="15" />
                                        <TextBlock x:Name="SetLabelAbout" Text="About" Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </StackPanel>

                        <!-- Section content -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden">
                            <Grid Padding="0,0,4,24">

                                <!-- ===== Profile ===== -->
                                <StackPanel x:Name="SetSecProfile" Spacing="20" Visibility="Visible">
                                    <TextBlock Text="Profile" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource AccentSoftBrush}" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE77B;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="Display name" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Shown in the greeting, sidebar and 'Made for…' carousel." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                    <Grid Margin="0,6,0,0" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" x:Name="DisplayNameBox" MaxLength="40" PlaceholderText="Listener" TextChanged="DisplayNameBox_TextChanged" KeyDown="DisplayNameBox_KeyDown" HorizontalAlignment="Stretch" />
                                                        <Button Grid.Column="1" x:Name="DisplayNameSaveButton" Click="DisplayNameSave_Click" Style="{StaticResource AccentButtonStyle}" CornerRadius="{StaticResource RadiusMd}" Padding="16,7" VerticalAlignment="Center" IsEnabled="False">
                                                            <TextBlock Text="Save" FontSize="12" FontWeight="SemiBold" />
                                                        </Button>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== Library ===== -->
                                <StackPanel x:Name="SetSecLibrary" Spacing="20" Visibility="Collapsed">
                                    <!-- Scanning banner (shown while a scan runs) -->
                                    <Border x:Name="SettingsScanCard" Visibility="Collapsed" CornerRadius="{StaticResource RadiusXl}" BorderBrush="{ThemeResource AccentSoft2Brush}" BorderThickness="1" Padding="18,16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{ThemeResource AccentColor}" Offset="0.0" />
                                                <GradientStop Color="{ThemeResource PanelGradient1}" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource SurfaceBrush}" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE149;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                                <TextBlock x:Name="ScanStatusText" Text="Scanning your music folder..." Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                <ProgressBar IsIndeterminate="True" Foreground="{ThemeResource AccentBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" x:Name="ScanCancelButton" Click="ScanCancel_Click" CornerRadius="{StaticResource RadiusMd}" Padding="12,6" VerticalAlignment="Center">
                                                <TextBlock Text="Cancel" FontSize="12" FontWeight="SemiBold" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Library Management" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <!-- Music folder -->
                                            <Grid ColumnSpacing="14">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource AccentSoftBrush}" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xED25;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="Music folder" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="The folder scanned for your local library." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                    <TextBox x:Name="MusicFolderPathBox" IsReadOnly="True" PlaceholderText="No folder selected" Margin="0,6,0,0" HorizontalAlignment="Stretch" />
                                                </StackPanel>
                                                <StackPanel x:Name="MusicFolderActions" Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Button x:Name="ChangeFolderButton" Click="ChangeFolderButton_Click" CornerRadius="{StaticResource RadiusMd}" Padding="14,7">
                                                        <TextBlock Text="Change" FontSize="12" FontWeight="SemiBold" />
                                                    </Button>
                                                    <Button x:Name="OpenFolderButton" Click="OpenFolderButton_Click" CornerRadius="{StaticResource RadiusMd}" Padding="14,7">
                                                        <TextBlock Text="Open" FontSize="12" FontWeight="SemiBold" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />

                                            <!-- Scan for music -->
                                            <Grid ColumnSpacing="14">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource AccentSoftBrush}" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE149;" FontSize="16" Foreground="{ThemeResource AccentBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="Scan for music" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Re-index the selected folder for new or changed tracks." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="2" x:Name="ScanMusicButton" Click="ScanMusicButton_Click" Style="{StaticResource AccentButtonStyle}" CornerRadius="{StaticResource RadiusMd}" Padding="16,7" VerticalAlignment="Center">
                                                    <TextBlock Text="Scan now" FontSize="12" FontWeight="SemiBold" />
                                                </Button>
                                            </Grid>

                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />

                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="File Formats" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Formats included when scanning. Backend currently indexes MP3 and FLAC." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Disabled">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ToggleButton x:Name="FmtMp3" Tag=".mp3" Content="MP3" IsChecked="True" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtFlac" Tag=".flac" Content="FLAC" IsChecked="True" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtWav" Tag=".wav" Content="WAV" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtM4a" Tag=".m4a" Content="M4A" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtAac" Tag=".aac" Content="AAC" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtOgg" Tag=".ogg" Content="OGG" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtOpus" Tag=".opus" Content="OPUS" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                    <ToggleButton x:Name="FmtWma" Tag=".wma" Content="WMA" Style="{StaticResource ChipToggle}" Checked="FormatChip_Toggled" Unchecked="FormatChip_Toggled" />
                                                </StackPanel>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== Playback ===== -->
                                <StackPanel x:Name="SetSecPlayback" Visibility="Collapsed" Spacing="20">
                                    <TextBlock Text="Playback" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Autoplay" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Keep playing related songs when your queue ends." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="AutoplaySwitch" Grid.Column="1" IsOn="True" Toggled="SettingsToggle_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            </Grid>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Gapless playback" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Remove silence between consecutive tracks." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="GaplessSwitch" Grid.Column="1" IsOn="True" Toggled="SettingsToggle_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            </Grid>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="When closing window" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Choose what the close button does." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ComboBox x:Name="CloseBehaviorCombo" Grid.Column="1" SelectedIndex="0" MinWidth="180" VerticalAlignment="Center" SelectionChanged="SettingsCombo_SelectionChanged">
                                                    <ComboBoxItem Content="Minimize to tray" />
                                                    <ComboBoxItem Content="Quit" />
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== Audio ===== -->
                                <StackPanel x:Name="SetSecAudio" Visibility="Collapsed" Spacing="20">
                                    <TextBlock Text="Audio" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Output device" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Where audio is rendered." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ComboBox x:Name="OutputDeviceCombo" Grid.Column="1" SelectedIndex="0" MinWidth="200" VerticalAlignment="Center" SelectionChanged="SettingsCombo_SelectionChanged">
                                                    <ComboBoxItem Content="System default" />
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="Equalizer" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                        <TextBlock Text="Coming soon" Style="{StaticResource CaptionText}" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Temporarily unavailable while audio processing is being revised." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}" Opacity="0.5">
                                        <StackPanel Spacing="16">
                                            <StackPanel Orientation="Vertical" Spacing="8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ToggleButton x:Name="EqPresetFlat" Tag="Flat" Content="Flat" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                    <ToggleButton x:Name="EqPresetBass" Tag="Bass" Content="Bass Boost" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                    <ToggleButton x:Name="EqPresetTreble" Tag="Treble" Content="Treble" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                    <ToggleButton x:Name="EqPresetVocal" Tag="Vocal" Content="Vocal" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <ToggleButton x:Name="EqPresetAcoustic" Tag="Acoustic" Content="Acoustic" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                    <ToggleButton x:Name="EqPresetElectronic" Tag="Electronic" Content="Electronic" Style="{StaticResource ChipToggle}" Click="EqualizerPreset_Click" IsEnabled="False" />
                                                    <ToggleButton x:Name="EqPresetCustom" Tag="Custom" Content="Custom" Style="{StaticResource ChipToggle}" IsEnabled="False" IsHitTestVisible="False" IsTabStop="False" ToolTipService.ToolTip="Highlights when bands do not match a preset" />
                                                    <Button x:Name="EqResetButton" Click="EqResetButton_Click" ToolTipService.ToolTip="Zero all bands and preamp" IsEnabled="False">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <FontIcon Glyph="&#xE777;" FontSize="12" />
                                                            <TextBlock Text="Reset" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="Preamp" Style="{StaticResource CaptionText}" Width="60" VerticalAlignment="Center" />
                                                <Slider x:Name="EqPreampSlider" Minimum="-12" Maximum="0" Value="0" StepFrequency="1" Width="200" VerticalAlignment="Center" ValueChanged="EqPreampSlider_ValueChanged" ToolTipService.ToolTip="Reduce signal before the bands to give boosts headroom" IsEnabled="False" />
                                                <TextBlock x:Name="EqPreampValueText" Text="0 dB" Width="56" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel x:Name="EqualizerBars" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== Appearance ===== -->
                                <StackPanel x:Name="SetSecAppearance" Visibility="Collapsed" Spacing="20">
                                    <TextBlock Text="Appearance" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Theme" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Switch between light, dark, or follow the system." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel x:Name="ThemeOptionsPanel" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <ToggleButton x:Name="ThemeLight" Tag="Light" Content="Light" Style="{StaticResource ChipToggle}" Checked="ThemeSegment_Checked" />
                                                    <ToggleButton x:Name="ThemeDark" Tag="Dark" Content="Dark" Style="{StaticResource ChipToggle}" Checked="ThemeSegment_Checked" />
                                                    <ToggleButton x:Name="ThemeSystem" Tag="System" Content="System" IsChecked="True" Style="{StaticResource ChipToggle}" Checked="ThemeSegment_Checked" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Accent color" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Recolors highlights, sliders and accents across the app." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel x:Name="AccentSwatchesPanel" Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <Ellipse x:Name="AccentSw0" Tag="#FF0097B2" Width="22" Height="22" Fill="{ThemeResource AccentBrush}" Stroke="{ThemeResource StrokeStrongBrush}" StrokeThickness="2" Tapped="AccentSwatch_Tapped" />
                                                    <Ellipse x:Name="AccentSw1" Tag="#FF6B8EFE" Width="22" Height="22" Fill="#FF6B8EFE" StrokeThickness="0" Tapped="AccentSwatch_Tapped" />
                                                    <Ellipse x:Name="AccentSw2" Tag="#FFE0719C" Width="22" Height="22" Fill="#FFE0719C" StrokeThickness="0" Tapped="AccentSwatch_Tapped" />
                                                    <Ellipse x:Name="AccentSw3" Tag="#FF6FBF73" Width="22" Height="22" Fill="#FF6FBF73" StrokeThickness="0" Tapped="AccentSwatch_Tapped" />
                                                    <Ellipse x:Name="AccentSw4" Tag="#FFE8A33D" Width="22" Height="22" Fill="#FFE8A33D" StrokeThickness="0" Tapped="AccentSwatch_Tapped" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Show album art on player bar" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Display artwork next to the now-playing track." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="ShowAlbumArtSwitch" Grid.Column="1" IsOn="True" Toggled="SettingsToggle_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== Integrations ===== -->
                                <StackPanel x:Name="SetSecIntegrations" Visibility="Collapsed" Spacing="20">
                                    <TextBlock Text="Integrations" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <Grid ColumnSpacing="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                                <TextBlock Text="Music Provider" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                <TextBlock x:Name="ProviderTestStatusText" Text="Ready" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button x:Name="ProviderTestButton" Grid.Row="0" Grid.Column="1" Click="PlayProviderTest_Click" CornerRadius="{StaticResource RadiusMd}" Padding="16,7" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8FB;" FontSize="13" />
                                                    <TextBlock Text="Test connection" FontSize="12" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                            <TextBox x:Name="ProviderBaseUrlBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="http://127.0.0.1:4527" Header="Provider URL" Margin="0,12,0,0" />
                                            <PasswordBox x:Name="ProviderApiKeyBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="API key" PasswordRevealMode="Peek" Margin="0,8,0,0" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Discord Rich Presence" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Show what you're listening to on Discord." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Requires the Discord desktop app to be running." Style="{StaticResource CaptionText}" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="DiscordPresenceSwitch" Grid.Column="1" Toggled="SettingsToggle_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            </Grid>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" Margin="0,16" />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="Windows media controls" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="System play/pause and media keys (SMTC)." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <ToggleSwitch x:Name="WindowsMediaControlsSwitch" Grid.Column="1" IsOn="True" Toggled="SettingsToggle_Toggled" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ===== About ===== -->
                                <StackPanel x:Name="SetSecAbout" Visibility="Collapsed" Spacing="20">
                                    <TextBlock Text="About" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                    <Border Style="{StaticResource SettingsCard}">
                                        <StackPanel Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <Border Width="56" Height="56" CornerRadius="{StaticResource RadiusXl}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="{ThemeResource AccentColor}" Offset="0.0" />
                                                            <GradientStop Color="{ThemeResource AccentColorLight}" Offset="1.0" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="&#x266A;" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="Last Music Player" Style="{StaticResource TitleH3}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Version 1.0.0" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" />
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Build" Style="{StaticResource EyebrowText}" />
                                                <TextBlock Text="Windows App SDK 1.8 · x64 · C++/WinRT (MSVC)" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Database" Style="{StaticResource EyebrowText}" />
                                                <TextBlock x:Name="AboutDbStats" Text="SQLite 3 · local library" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button x:Name="OpenDataFolderButton" Click="OpenDataFolder_Click" CornerRadius="{StaticResource RadiusMd}" Padding="16,8">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xED43;" FontSize="14" />
                                                        <TextBlock Text="Open data folder" FontSize="12" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="LicensesButton" Click="ShowLicenses_Click" CornerRadius="{StaticResource RadiusMd}" Padding="16,8">
                                                    <TextBlock Text="Licenses &amp; credits" FontSize="12" FontWeight="SemiBold" />
                                                </Button>
                                                <Button x:Name="ResetDefaultsButton" Click="ResetDefaults_Click" CornerRadius="{StaticResource RadiusMd}" Padding="16,8">
                                                    <TextBlock Text="Reset to defaults" FontSize="12" FontWeight="SemiBold" />
                                                </Button>
                                            </StackPanel>
                                            <Border Height="1" Background="{ThemeResource DividerBrush}" />
                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource DangerSoftBrush}" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource DangerBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="Clean up everything" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                                    <TextBlock Text="Wipe library, playback history, queues, settings, provider config and caches." Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                                                    <TextBlock x:Name="WipeAllDataStatusText" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Visibility="Collapsed" />
                                                </StackPanel>
                                                <Button x:Name="WipeAllDataButton" Grid.Column="2" Click="WipeAllData_Click" Background="{ThemeResource DangerBrush}" Foreground="White" BorderThickness="0" CornerRadius="{StaticResource RadiusMd}" Padding="16,8" VerticalAlignment="Center">
                                                    <TextBlock Text="Clean up" FontSize="12" FontWeight="SemiBold" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ========== BROWSE VIEW ========== -->
                <Grid x:Name="BrowseViewContainer"
                      Visibility="Collapsed">
                <Grid Padding="0,16,8,24">
                    <Grid.Resources>
                        <!-- Lightweight override: playing/selected row uses accent-soft -->
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{ThemeResource AccentColor}" Opacity="0.12" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{ThemeResource AccentColor}" Opacity="0.16" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="{ThemeResource AccentColor}" Opacity="0.18" />
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title block -->
                        <RowDefinition Height="Auto" /> <!-- Toolbar -->
                        <RowDefinition Height="Auto" /> <!-- Header row -->
                        <RowDefinition Height="*" />    <!-- Table -->
                    </Grid.RowDefinitions>

                    <!-- Title block -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="BrowseScopeLabel" Text="Local Library" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="Browse" Style="{StaticResource TitleH1}" />
                            <TextBlock x:Name="BrowseSubtitle" Text="No tracks scanned yet" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="BrowseRescanButton" Click="BrowseRescan_Click" CornerRadius="{StaticResource RadiusLg}" Padding="14,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE149;" FontSize="14" />
                                    <TextBlock Text="Rescan" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="BrowsePlayAllButton" Click="BrowsePlayAll_Click" Style="{StaticResource AccentButtonStyle}" CornerRadius="{StaticResource RadiusLg}" Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Play all" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Toolbar: filter chips + view toggle / sort -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <ToggleButton x:Name="ChipAll" Tag="All" Content="All" IsChecked="True" Style="{StaticResource ChipToggle}" Checked="BrowseChip_Checked" Unchecked="BrowseChip_Unchecked" />
                            <ToggleButton x:Name="ChipHistory" Tag="History" Content="History" Style="{StaticResource ChipToggle}" Checked="BrowseChip_Checked" Unchecked="BrowseChip_Unchecked" />
                            <ToggleButton x:Name="ChipMost" Tag="Most" Content="Most played" Style="{StaticResource ChipToggle}" Checked="BrowseChip_Checked" Unchecked="BrowseChip_Unchecked" />
                            <ToggleButton x:Name="ChipFav" Tag="Fav" Content="Favourites" Style="{StaticResource ChipToggle}" Checked="BrowseChip_Checked" Unchecked="BrowseChip_Unchecked" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border CornerRadius="{StaticResource RadiusMd}" Background="{ThemeResource NeutralFillBrush}" Padding="3">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BrowseListViewButton" Click="BrowseListView_Click" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusSm}" Padding="8,5" AutomationProperties.Name="List view">
                                        <FontIcon Glyph="&#xEA37;" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    </Button>
                                    <Button x:Name="BrowseGridViewButton" Click="BrowseGridView_Click" Background="Transparent" BorderThickness="0" CornerRadius="{StaticResource RadiusSm}" Padding="8,5" AutomationProperties.Name="Grid view">
                                        <FontIcon Glyph="&#xE80A;" FontSize="14" Foreground="{ThemeResource TextTertiaryBrush}" />
                                    </Button>
                                </StackPanel>
                            </Border>
                            <DropDownButton x:Name="BrowseSortButton" CornerRadius="{StaticResource RadiusMd}" Padding="12,7">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="BrowseSortLabel" Text="Date added" FontSize="12" FontWeight="SemiBold" />
                                </StackPanel>
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Date added" Tag="DateAdded" Click="BrowseSort_Click" />
                                        <MenuFlyoutItem Text="Title" Tag="Title" Click="BrowseSort_Click" />
                                        <MenuFlyoutItem Text="Artist" Tag="Artist" Click="BrowseSort_Click" />
                                        <MenuFlyoutItem Text="Duration" Tag="Duration" Click="BrowseSort_Click" />
                                        <MenuFlyoutItem Text="Most played" Tag="MostPlayed" Click="BrowseSort_Click" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </StackPanel>
                    </Grid>

                    <!-- Header row -->
                    <Grid x:Name="BrowseListHeader" Grid.Row="2" Padding="16,9" ColumnSpacing="10"
                          Background="{ThemeResource SurfaceAltBrush}"
                          BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="106" />
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" Style="{StaticResource EyebrowText}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="TITLE" Style="{StaticResource EyebrowText}" />
                        <TextBlock Grid.Column="2" Text="ALBUM" Style="{StaticResource EyebrowText}" />
                        <TextBlock Grid.Column="3" Text="ADDED" Style="{StaticResource EyebrowText}" />
                        <TextBlock Grid.Column="4" Text="TIME" Style="{StaticResource EyebrowText}" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="5" Text="" Style="{StaticResource EyebrowText}" />
                    </Grid>

                    <!-- Table -->
                    <ListView x:Name="MusicListView" Grid.Row="3"
                              IsItemClickEnabled="True"
                              ItemClick="MusicListView_ItemClick"
                              ContainerContentChanging="BrowseList_ContainerContentChanging"
                              SelectionMode="Single"
                              VerticalAlignment="Stretch"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="16,0" />
                                <Setter Property="MinHeight" Value="56" />
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:TrackInfo">
                                <Grid x:Name="RowRoot" Height="56" ColumnSpacing="10"
                                      PointerEntered="Row_PointerEntered" PointerExited="Row_PointerExited">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="106" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>

                                    <!-- # / play (hover) -->
                                    <Grid Grid.Column="0">
                                        <TextBlock x:Name="RowNum" Text="{x:Bind Index}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="13" />
                                        <Button x:Name="RowPlay"
                                                Tag="{x:Bind}"
                                                Click="BrowseRowPlay_Click"
                                                Visibility="Collapsed"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                MinWidth="28"
                                                Width="28"
                                                Height="28"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Play track">
                                            <FontIcon Glyph="&#xE768;" FontSize="12" Foreground="{ThemeResource AccentBrush}" />
                                        </Button>
                                    </Grid>

                                    <!-- Title / Artist -->
                                    <Grid Grid.Column="1" ColumnSpacing="10" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="{StaticResource RadiusMd}" Background="{ThemeResource NeutralFillBrush}">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8D6;" FontSize="14" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsHitTestVisible="False" AutomationProperties.AccessibilityView="Raw" />
                                                    <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                            <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Grid.Column="2" Text="{x:Bind Album}" VerticalAlignment="Center" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind DateAdded}" VerticalAlignment="Center" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind Duration}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="13" />
                                    <Button Grid.Column="5"
                                            Tag="{x:Bind}"
                                            Style="{StaticResource IconOnlyButton}"
                                            VerticalAlignment="Center"
                                            AutomationProperties.Name="More options">
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNow_Click" />
                                                <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                                <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                                <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                        <FontIcon Glyph="&#xE712;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <GridView x:Name="BrowseGridView" Grid.Row="3"
                              Visibility="Collapsed"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="BrowseGridView_ItemClick"
                              ItemContainerStyle="{StaticResource CardTileContainerStyle}"
                              ContainerContentChanging="BrowseGrid_ContainerContentChanging"
                              Padding="0,4,8,24"
                              VerticalAlignment="Stretch"
                              ScrollViewer.VerticalScrollMode="Enabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- ItemHeight covers the card's actual layout footprint:
                                     172 image + 10 image margin + 3 text lines (~19+16+16)
                                     + 24 StackPanel bottom margin = ~257. Previous 234
                                     truncated the third text row + spilled it into the
                                     next row's images. -->
                                <ItemsWrapGrid Orientation="Horizontal" ItemWidth="192" ItemHeight="264" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:TrackInfo">
                                <!-- Browse tiles had no hover affordance of their own and
                                     leaned on the stock GridViewItem fill. Now that the
                                     container chrome is stripped (CardTileContainerStyle),
                                     give them the same -2px "lift" the other card grids use
                                     so hover feedback stays consistent. -->
                                <StackPanel Width="172" Margin="0,0,20,24"
                                            PointerEntered="Card_PointerEntered" PointerExited="Card_PointerExited">
                                    <StackPanel.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNow_Click" />
                                            <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuPlayNext_Click" />
                                            <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAddToQueue_Click" />
                                            <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                            <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuAlbum_Click" />
                                        </MenuFlyout>
                                    </StackPanel.ContextFlyout>
                                    <Border Width="172" Height="172" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource NeutralFillBrush}" Margin="0,0,0,10">
                                        <Grid>
                                            <FontIcon Glyph="&#xE8D6;" FontSize="40" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      IsHitTestVisible="False" AutomationProperties.AccessibilityView="Raw" />
                                            <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    <TextBlock Text="{x:Bind SourceLabel}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
                </Grid>

                <!-- ========== LIBRARY VIEW ========== -->
                <Grid x:Name="LibraryViewContainer" Visibility="Collapsed" Padding="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title block -->
                        <RowDefinition Height="Auto" /> <!-- Tabs -->
                        <RowDefinition Height="*" />    <!-- Content -->
                    </Grid.RowDefinitions>

                    <!-- Title block -->
                    <Grid x:Name="LibraryHeaderBar" Grid.Row="0" Margin="0,0,0,24" SizeChanged="LibraryHeaderBar_SizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                            <TextBlock Text="YOUR COLLECTION" Style="{StaticResource EyebrowText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                            <TextBlock Text="Library" Style="{StaticResource TitleH1}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                            <TextBlock x:Name="LibrarySubtitle" Text="Albums, artists and everything you've collected" FontSize="13" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                            <TextBlock x:Name="LibraryImportStatusText" Text="" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Library header actions. Each glyph is intentionally
                                 distinct so compact (icon-only) mode doesn't reduce
                                 multiple buttons to identical plus signs. -->
                            <Button x:Name="LibraryCreateAlbumButton" Click="LibraryCreateAlbum_Click" CornerRadius="{StaticResource RadiusLg}" Padding="12,8" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE93C;" FontSize="16" />
                                    <TextBlock x:Name="LblCreateAlbum" Text="Create album" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LibraryImportAlbumButton" Click="LibraryImportAlbum_Click" Style="{StaticResource AccentButtonStyle}" CornerRadius="{StaticResource RadiusLg}" Padding="12,8" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" FontSize="16" />
                                    <TextBlock x:Name="LblImportAlbum" Text="Import album" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LibraryCreatePlaylistButton" Click="LibraryCreatePlaylist_Click" CornerRadius="{StaticResource RadiusLg}" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE142;" FontSize="16" />
                                    <TextBlock x:Name="LblCreatePlaylist" Text="Create playlist" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LibraryImportPlaylistButton" Click="LibraryImportPlaylist_Click" Style="{StaticResource AccentButtonStyle}" CornerRadius="{StaticResource RadiusLg}" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" FontSize="16" />
                                    <TextBlock x:Name="LblImportPlaylist" Text="Import playlist" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="LibraryAddFolderButton" Click="LibraryAddFolder_Click" CornerRadius="{StaticResource RadiusLg}" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="16" />
                                    <TextBlock x:Name="LblAddFolder" Text="Add folder" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Tabs + sort -->
                    <Grid x:Name="LibraryNavigationBar" Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <ToggleButton x:Name="LibTabPlaylists" Tag="Playlists" Content="Playlists" IsChecked="True" Style="{StaticResource ChipToggle}" Checked="LibraryTab_Checked" />
                            <ToggleButton x:Name="LibTabAlbums" Tag="Albums" Content="Albums" Style="{StaticResource ChipToggle}" Checked="LibraryTab_Checked" />
                            <ToggleButton x:Name="LibTabArtists" Tag="Artists" Content="Artists" Style="{StaticResource ChipToggle}" Checked="LibraryTab_Checked" />
                            <ToggleButton x:Name="LibTabSongs" Tag="Songs" Content="Songs" Style="{StaticResource ChipToggle}" Checked="LibraryTab_Checked" />
                            <ToggleButton x:Name="LibTabGenres" Tag="Genres" Content="Genres" Style="{StaticResource ChipToggle}" Checked="LibraryTab_Checked" />
                        </StackPanel>
                        <DropDownButton Grid.Column="1" CornerRadius="{StaticResource RadiusMd}" Padding="12,7" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Recently added" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Recently added" />
                                    <MenuFlyoutItem Text="Name" />
                                    <MenuFlyoutItem Text="Artist" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </Grid>

                    <!-- Content: Albums / Artists / Songs / Genres -->
                    <Grid x:Name="LibraryTabsContent" Grid.Row="2">
                        <!-- Albums -->
                        <GridView x:Name="LibAlbumsGrid" Visibility="Collapsed" SelectionMode="None" IsItemClickEnabled="True" ItemClick="LibraryGroup_ItemClick" ItemContainerStyle="{StaticResource CardTileContainerStyle}" Padding="0,0,0,24"
                                  ScrollViewer.HorizontalScrollMode="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="local:TrackInfo">
                                    <StackPanel Width="168" Margin="0,0,16,18" VerticalAlignment="Top" PointerEntered="PlaylistCard_PointerEntered" PointerExited="PlaylistCard_PointerExited">
                                        <StackPanel.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryGroupMenuPlayNow_Click" />
