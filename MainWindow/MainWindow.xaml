                                                <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuPlayNext_Click" />
                                                <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToQueue_Click" />
                                                <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                <MenuFlyoutItem Text="Remove from playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuRemoveFromPlaylist_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAlbum_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Index}" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="{StaticResource RadiusMd}" Background="{ThemeResource NeutralFillBrush}">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8D6;" FontSize="15" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrong}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                            <TextBlock Text="{x:Bind Artist}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{x:Bind Duration}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        <Button Grid.Column="4"
                                                Tag="{x:Bind}"
                                                Style="{StaticResource IconOnlyButton}"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="More options">
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuPlayNow_Click" />
                                                    <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuPlayNext_Click" />
                                                    <MenuFlyoutItem Text="Add to queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToQueue_Click" />
                                                    <MenuFlyoutItem Text="Add to playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAddToPlaylist_Click" />
                                                    <MenuFlyoutItem Text="Remove from playlist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuRemoveFromPlaylist_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="{x:Bind LikeActionText}" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuLike_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Go to artist" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="BrowseRowMenuArtist_Click" />
                                                    <MenuFlyoutItem Text="Go to album" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="LibraryRowMenuAlbum_Click" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                            <FontIcon Glyph="&#xE712;" FontSize="13" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

            </Grid>

            <!-- Right Sidebar Panel -->
            <Grid x:Name="RightSidebar" Grid.Column="2" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="1,0,0,0" Padding="0,48,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Up Next / Lyrics tabs -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Segmented Up Next / Lyrics tabs -->
                <Border Grid.Row="0" Margin="24,24,24,16" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource NeutralFillBrush}" Padding="3">
                    <Grid x:Name="RailTabStrip">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="RailTabThumb" Grid.Column="0" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" />
                        <Border Grid.Column="0" Background="Transparent" Tapped="RailTab_UpNext_Tapped">
                            <TextBlock x:Name="UpNextTabText" Text="Up Next" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Padding="0,7" Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </Border>
                        <Border Grid.Column="1" Background="Transparent" Tapped="RailTab_Lyrics_Tapped">
                            <TextBlock x:Name="LyricsTabText" Text="Lyrics" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Padding="0,7" Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                <ScrollViewer x:Name="UpNextContentPanel" VerticalScrollBarVisibility="Hidden">
                    <StackPanel Padding="24,8,24,24">
                        <TextBlock Text="NOW PLAYING" Style="{StaticResource EyebrowText}" Margin="0,0,0,16"/>

                        <!-- Album Art (1:1 square aspect ratio) -->
                        <Grid Width="252" Height="252" Margin="0,0,0,24">
                            <Border CornerRadius="{StaticResource Radius2xl}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{ThemeResource ArtPlaceholderGrad1}" Offset="0.0"/>
                                        <GradientStop Color="{ThemeResource ArtPlaceholderGrad2}" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid x:Name="RightPanelGeneratedArtwork">
                                    <Grid.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF0097B2" Offset="0.0"/>
                                            <GradientStop Color="#FF00B8D4" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Grid.Background>
                                    <FontIcon x:Name="RightPanelGeneratedGlyph" Glyph="&#xE8D6;" FontSize="112" Foreground="White" Opacity="0.18" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0" IsHitTestVisible="False" />
                                    <Border IsHitTestVisible="False" CornerRadius="{StaticResource Radius2xl}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="0.4"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock x:Name="RightPanelGeneratedTitle" Text="MUSIC" FontSize="12" FontWeight="Bold" CharacterSpacing="180" Foreground="White" Opacity="0.95" VerticalAlignment="Top" Margin="18" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                    <TextBlock x:Name="RightPanelGeneratedCaption" Text="Select a track" FontSize="13" FontWeight="Medium" Foreground="White" Opacity="0.94" TextWrapping="Wrap" LineHeight="18" VerticalAlignment="Bottom" Margin="18" MaxLines="3" TextTrimming="WordEllipsis" />
                                </Grid>
                            </Border>
                            <Border CornerRadius="{StaticResource Radius2xl}">
                                <Image x:Name="RightPanelArt" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{x:Null}" />
                            </Border>
                        </Grid>

                        <!-- Song Info -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock x:Name="NowPlayingTitle" Text="Not Playing" Style="{StaticResource TitleH2}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="NowPlayingArtist" Text="Select a track" FontSize="14" Foreground="{ThemeResource AccentBrush}"/>
                            <!-- Meta row: album · year · format/bitrate (wired in a later phase) -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <TextBlock x:Name="NpMetaAlbum" Text="&#x2014;" FontSize="11.5" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="NpMetaYear" Text="&#x2014;" FontSize="11.5" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="NpMetaFormat" Text="&#x2014;" FontSize="11.5" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Queue Header -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NEXT IN QUEUE" Style="{StaticResource EyebrowText}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="See All" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Queue Items -->
                        <ListView x:Name="UpNextListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  CanReorderItems="True"
                                  CanDragItems="True"
                                  AllowDrop="True"
                                  ReorderMode="Enabled"
                                  DragItemsCompleted="UpNextQueue_DragItemsCompleted"
                                  ScrollViewer.VerticalScrollMode="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:TrackInfo">
                                    <Grid Padding="0,0,0,12" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueuePlayNow_Click" />
                                                <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueuePlayNext_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Move up" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueMoveUp_Click" />
                                                <MenuFlyoutItem Text="Move down" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueMoveDown_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Remove from queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueRemove_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>

                                        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="{StaticResource RadiusMd}" Background="{ThemeResource NeutralFillBrush}">
                                            <Grid>
                                                <FontIcon Glyph="&#xE8D6;" FontSize="16" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                            <TextBlock Text="{x:Bind Artist}" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </StackPanel>
                </ScrollViewer>

                <!-- Lyrics content (sibling of UpNextContentPanel). Toggled by SetRailTab. -->
                <Grid x:Name="LyricsContentPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Padding="24,8,24,16">
                        <TextBlock Text="LYRICS" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="LyricsTrackTitle" Style="{StaticResource TitleH3}" Text="Not Playing" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock x:Name="LyricsTrackArtist" Text="Select a track" FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        <TextBlock x:Name="LyricsSourceTag" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" Margin="0,4,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <ScrollViewer x:Name="LyricsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
                        <Grid>
                            <StackPanel x:Name="LyricsLinesPanel" Spacing="14" Visibility="Collapsed"/>
                            <TextBlock x:Name="LyricsPlainText" Visibility="Collapsed" FontSize="15" LineHeight="22" TextWrapping="Wrap" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            <StackPanel x:Name="LyricsEmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,48,0,0">
                                <FontIcon x:Name="LyricsEmptyGlyph" Glyph="&#xE8D6;" FontSize="40" Opacity="0.5" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LyricsEmptyMessage" Text="Tap Lyrics while a song is playing." HorizontalAlignment="Center" TextAlignment="Center" Margin="0,12,0,0" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap" MaxWidth="280"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
                </Grid>
            </Grid>

        </Grid>

        <!-- Bottom Player Bar -->
        <Grid Grid.Row="1" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,1,0,0" Padding="24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" /> <!-- Left: Track Info -->
                <ColumnDefinition Width="*" />   <!-- Center: Controls -->
                <ColumnDefinition Width="300" /> <!-- Right: Extra Controls -->
            </Grid.ColumnDefinitions>

            <!-- Left: Track Info -->
            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="BottomArtContainer" Grid.Column="0" Width="52" Height="52" Margin="0,0,16,0">
                    <Border CornerRadius="{StaticResource RadiusLg}">
                        <Grid x:Name="BottomGeneratedArtwork">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF0097B2" Offset="0.0"/>
                                    <GradientStop Color="#FF00B8D4" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <FontIcon x:Name="BottomGeneratedGlyph" Glyph="&#xE8D6;" FontSize="46" Foreground="White" Opacity="0.20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0" IsHitTestVisible="False" />
                            <Border IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.45"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>
                    <Border CornerRadius="{StaticResource RadiusLg}">
                        <Image x:Name="BottomPlayerArt" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{x:Null}" />
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="BottomPlayerTitle" Text="Not Playing" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                    <TextBlock x:Name="BottomPlayerArtist" Text="Select a track" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                </StackPanel>

                <Button x:Name="BottomLikeButton" Grid.Column="2" Style="{StaticResource IconOnlyButton}" Margin="16,0,0,0" Click="LikeCurrentTrack_Click" AutomationProperties.Name="Like this track">
                    <FontIcon x:Name="BottomLikeIcon" Glyph="&#xEB51;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="16"/>
                </Button>
            </Grid>

            <!-- Center: Controls and Seek Bar -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500" Width="400">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" Margin="0,0,0,8">
                    <Button x:Name="ShuffleButton" Click="ShuffleButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Shuffle">
                        <FontIcon x:Name="ShuffleIcon" Glyph="&#xE8B1;" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="16" />
                    </Button>
                    <Button x:Name="PreviousButton" Click="PreviousButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Previous track">
                        <FontIcon Glyph="&#xEB9E;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="20" />
                    </Button>
                    <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Background="{ThemeResource PlayerPlayBackground}" CornerRadius="20" Width="40" Height="40" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AutomationProperties.Name="Play or pause">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" Foreground="{ThemeResource PlayerPlayForeground}" FontSize="16"/>
                    </Button>

                    <Button x:Name="NextButton" Click="NextButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Next track">
                        <FontIcon Glyph="&#xE893;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="20" />
                    </Button>
                    <Button x:Name="RepeatButton" Click="RepeatButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Repeat">
                        <FontIcon x:Name="RepeatIcon" Glyph="&#xE8EE;" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="16" />
                    </Button>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="CurrentTimeText" Grid.Column="0" Text="0:00" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <!-- Timeline progress bar: visuals are a Border + Border + ScaleTransform
                         (same pattern as the volume indicator above) so the fill deterministically
                         reaches the right edge at 100%. The invisible Slider on top owns
                         interaction (click-to-seek via ValueChanged). Without this split,
                         WinUI Slider's HorizontalDecreaseRect layout leaves an unfilled stub
                         at end-of-track even when Value == Maximum. -->
                    <Grid Grid.Column="1" Height="20" VerticalAlignment="Center">
                        <Border Height="4" CornerRadius="2" Background="{ThemeResource StrokeStrongBrush}" VerticalAlignment="Center" />
                        <Border Height="4" CornerRadius="2" Background="{ThemeResource AccentBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Center" RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="PlaybackProgressFillScale" ScaleX="0" />
                            </Border.RenderTransform>
                        </Border>
                        <Slider x:Name="PlaybackSlider" Background="Transparent" Foreground="Transparent" VerticalAlignment="Center"
                                Minimum="0" Maximum="100" Value="0"
                                ValueChanged="TimelineSlider_ValueChanged">
                            <Slider.Resources>
                                <x:Double x:Key="SliderHorizontalThumbWidth">0</x:Double>
                                <x:Double x:Key="SliderHorizontalThumbHeight">0</x:Double>
                                <x:Double x:Key="SliderInnerThumbWidth">0</x:Double>
                                <x:Double x:Key="SliderInnerThumbHeight">0</x:Double>
                                <SolidColorBrush x:Key="SliderTrackFill" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackFillPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackValueFill" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderThumbBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="Transparent" />
                            </Slider.Resources>
                        </Slider>
                    </Grid>

                    <TextBlock x:Name="TotalTimeText" Grid.Column="2" Text="0:00" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
            </StackPanel>

            <!-- Right: Extra Controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
                <Button x:Name="QueueButton" Click="QueueButton_Click" Style="{StaticResource IconOnlyButton}" AutomationProperties.Name="Queue">
                    <FontIcon Glyph="&#xE71D;" FontSize="16" /> <!-- Queue -->
                </Button>
                <Button x:Name="EqualizerButton" Click="EqualizerButton_Click" Style="{StaticResource IconOnlyButton}" IsEnabled="False" Opacity="0.5" ToolTipService.ToolTip="Equalizer - coming soon" AutomationProperties.Name="Equalizer coming soon">
                    <FontIcon Glyph="&#xF4C3;" FontSize="16" /> <!-- Equalizer -->
                </Button>
                <Button x:Name="CastButton" Click="CastButton_Click" Style="{StaticResource IconOnlyButton}" AutomationProperties.Name="Cast">
                    <FontIcon x:Name="CastIcon" Glyph="&#xEC15;" FontSize="16" /> <!-- Cast -->
                </Button>
                <Button x:Name="ExpandButton" Click="ExpandButton_Click" Style="{StaticResource IconOnlyButton}" Margin="0,0,8,0" AutomationProperties.Name="Full screen player">
                    <FontIcon Glyph="&#xE740;" FontSize="16" /> <!-- Full screen -->
                </Button>
                <Button x:Name="MuteButton" Click="MuteButton_Click" Style="{StaticResource IconOnlyButton}" AutomationProperties.Name="Mute">
                    <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="16" VerticalAlignment="Center"/> <!-- Volume -->
                </Button>
                <Grid Width="100" Height="24" VerticalAlignment="Center">
                    <Border Height="4" CornerRadius="2" Background="{ThemeResource StrokeStrongBrush}" VerticalAlignment="Center" />
                    <Border Height="4" CornerRadius="2" Background="{ThemeResource AccentBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Center" RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="VolumeFillScale" ScaleX="0.5" />
                        </Border.RenderTransform>
                    </Border>
                    <Slider x:Name="VolumeSlider" Background="Transparent" Foreground="Transparent" VerticalAlignment="Center"
                            Minimum="0" Maximum="100" StepFrequency="1" Value="50"
                            ValueChanged="VolumeSlider_ValueChanged">
                        <Slider.Resources>
                            <x:Double x:Key="SliderHorizontalThumbWidth">0</x:Double>
                            <x:Double x:Key="SliderHorizontalThumbHeight">0</x:Double>
                            <x:Double x:Key="SliderInnerThumbWidth">0</x:Double>
                            <x:Double x:Key="SliderInnerThumbHeight">0</x:Double>
                            <SolidColorBrush x:Key="SliderTrackFill" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackFillPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackValueFill" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderThumbBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="Transparent" />
                        </Slider.Resources>
                    </Slider>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Full-screen Now Playing overlay -->
        <Grid x:Name="NowPlayingFullScreen" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Canvas.ZIndex="50">
            <Grid Margin="40,24,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <!-- Top bar -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                    <Button x:Name="FsCloseButton" Click="FsCloseButton_Click" Style="{StaticResource IconOnlyButton}"
                            HorizontalAlignment="Left" AutomationProperties.Name="Close full screen">
                        <FontIcon Glyph="&#xE74B;" FontSize="16" />
                    </Button>
                    <TextBlock Text="NOW PLAYING" Style="{StaticResource EyebrowText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- Now playing: art + controls -->
                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="520" Spacing="20">
                    <Grid Width="340" Height="340" HorizontalAlignment="Center">
                        <Border CornerRadius="{StaticResource RadiusXl}">
                            <Grid x:Name="FsGeneratedArtwork">
                                <Grid.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF0097B2" Offset="0.0"/>
                                        <GradientStop Color="#FF00B8D4" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Grid.Background>
                                <FontIcon x:Name="FsGeneratedGlyph" Glyph="&#xE8D6;" FontSize="120" Foreground="White" Opacity="0.20" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <Border CornerRadius="{StaticResource RadiusXl}">
                            <Image x:Name="FsArt" Stretch="UniformToFill" Source="{x:Null}" />
                        </Border>
                    </Grid>

                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="FsTitle" Text="Not Playing" FontWeight="Bold" FontSize="24" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="FsArtist" Text="Select a track" FontSize="15" Foreground="{ThemeResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                        </StackPanel>
                        <Button x:Name="FsLike" Grid.Column="1" Click="LikeCurrentTrack_Click" Style="{StaticResource IconOnlyButton}" AutomationProperties.Name="Like this track">
                            <FontIcon x:Name="FsLikeIcon" Glyph="&#xEB51;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="20"/>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FsCurrentTime" Grid.Column="0" Text="0:00" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <!-- Full-screen timeline mirrors the bottom transport's visual-vs-
                             interaction split for the same end-of-track fill reasons. -->
                        <Grid Grid.Column="1" Height="20" VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{ThemeResource StrokeStrongBrush}" VerticalAlignment="Center" />
                            <Border Height="4" CornerRadius="2" Background="{ThemeResource AccentBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Center" RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="FsProgressFillScale" ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                            <Slider x:Name="FsSlider" Background="Transparent" Foreground="Transparent" VerticalAlignment="Center"
                                    Minimum="0" Maximum="100" Value="0"
                                    ValueChanged="TimelineSlider_ValueChanged">
                                <Slider.Resources>
                                    <x:Double x:Key="SliderHorizontalThumbWidth">0</x:Double>
                                    <x:Double x:Key="SliderHorizontalThumbHeight">0</x:Double>
                                    <x:Double x:Key="SliderInnerThumbWidth">0</x:Double>
                                    <x:Double x:Key="SliderInnerThumbHeight">0</x:Double>
                                    <SolidColorBrush x:Key="SliderTrackFill" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackFillPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackValueFill" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderThumbBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="Transparent" />
                                </Slider.Resources>
                            </Slider>
                        </Grid>
                        <TextBlock x:Name="FsTotalTime" Grid.Column="2" Text="0:00" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                        <Button x:Name="FsShuffle" Click="ShuffleButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Shuffle">
                            <FontIcon x:Name="FsShuffleIcon" Glyph="&#xE8B1;" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="18" />
                        </Button>
                        <Button x:Name="FsPrevious" Click="PreviousButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Previous track">
                            <FontIcon Glyph="&#xEB9E;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="24" />
                        </Button>
                        <Button x:Name="FsPlayPause" Click="PlayPauseButton_Click" Background="{ThemeResource PlayerPlayBackground}" CornerRadius="28" Width="56" Height="56" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AutomationProperties.Name="Play or pause">
                            <FontIcon x:Name="FsPlayPauseIcon" Glyph="&#xE768;" Foreground="{ThemeResource PlayerPlayForeground}" FontSize="22"/>
                        </Button>
                        <Button x:Name="FsNext" Click="NextButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Next track">
                            <FontIcon Glyph="&#xE893;" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="24" />
                        </Button>
                        <Button x:Name="FsRepeat" Click="RepeatButton_Click" Background="Transparent" BorderThickness="0" Padding="8" AutomationProperties.Name="Repeat">
                            <FontIcon x:Name="FsRepeatIcon" Glyph="&#xE8EE;" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="18" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Up Next / Lyrics -->
                <Grid Grid.Row="1" Grid.Column="1" Margin="32,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Segmented tabs mirror the right rail -->
                    <Border Grid.Row="0" Margin="0,0,0,16" CornerRadius="{StaticResource RadiusLg}" Background="{ThemeResource NeutralFillBrush}" Padding="3">
                        <Grid x:Name="FsRailTabStrip">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="FsRailTabThumb" Grid.Column="0" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" />
                            <Border Grid.Column="0" Background="Transparent" Tapped="RailTab_UpNext_Tapped">
                                <TextBlock x:Name="FsUpNextTabText" Text="Up Next" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Padding="0,7" Foreground="{ThemeResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="1" Background="Transparent" Tapped="RailTab_Lyrics_Tapped">
                                <TextBlock x:Name="FsLyricsTabText" Text="Lyrics" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Padding="0,7" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Toggled content -->
                    <Grid Grid.Row="1">
                    <Grid x:Name="FsUpNextContentPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="NEXT IN QUEUE" Style="{StaticResource EyebrowText}" Margin="0,0,0,12" />
                        <ListView x:Name="FsUpNext" Grid.Row="1"
                              SelectionMode="None" IsItemClickEnabled="False"
                              CanReorderItems="True" CanDragItems="True" AllowDrop="True"
                              ReorderMode="Enabled"
                              DragItemsCompleted="UpNextQueue_DragItemsCompleted">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:TrackInfo">
                                <Grid Padding="0,0,0,12" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Play now" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueuePlayNow_Click" />
                                            <MenuFlyoutItem Text="Play next" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueuePlayNext_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="Move up" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueMoveUp_Click" />
                                            <MenuFlyoutItem Text="Move down" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueMoveDown_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="Remove from queue" Tag="{x:Bind}" CommandParameter="{x:Bind}" Click="QueueRemove_Click" />
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="{StaticResource RadiusMd}" Background="{ThemeResource NeutralFillBrush}">
                                        <Grid>
                                            <FontIcon Glyph="&#xE8D6;" FontSize="16" Foreground="{ThemeResource PlaceholderGlyphBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Image Source="{x:Bind AlbumArt}" Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="14" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        <TextBlock Text="{x:Bind Artist}" Foreground="{ThemeResource TextTertiaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    </Grid>

                    <!-- Fullscreen lyrics panel (sibling of FsUpNextContentPanel). -->
                    <Grid x:Name="FsLyricsContentPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="LYRICS" Style="{StaticResource EyebrowText}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="FsLyricsTrackTitle" Style="{StaticResource TitleH3}" Text="Not Playing" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="FsLyricsTrackArtist" Text="Select a track" FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                            <TextBlock x:Name="FsLyricsSourceTag" FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}" Margin="0,4,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <ScrollViewer x:Name="FsLyricsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <StackPanel x:Name="FsLyricsLinesPanel" Spacing="16" Visibility="Collapsed"/>
                                <TextBlock x:Name="FsLyricsPlainText" Visibility="Collapsed" FontSize="16" LineHeight="24" TextWrapping="Wrap" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <StackPanel x:Name="FsLyricsEmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,48,0,0">
                                    <FontIcon x:Name="FsLyricsEmptyGlyph" Glyph="&#xE8D6;" FontSize="48" Opacity="0.5" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FsLyricsEmptyMessage" Text="Tap Lyrics while a song is playing." HorizontalAlignment="Center" TextAlignment="Center" Margin="0,12,0,0" Foreground="{ThemeResource TextTertiaryBrush}" TextWrapping="Wrap" MaxWidth="320"/>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

    </Grid>
</Window>
